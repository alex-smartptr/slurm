# Automatically copy over automake conditionals with...
# grep -E '[a-zA-Z0-9_]+_TRUE=$' configure | sed 's/ *\([a-zA-Z0-9_]*\)_TRUE=/@\1_TRUE@\1 := 1/' | sort -u >> config.mk.in

@AMDEP_TRUE@AMDEP := 1
@am__EXEEXT_TRUE@am__EXEEXT := 1
@am__fastdepCC_TRUE@am__fastdepCC := 1
@am__fastdepCXX_TRUE@am__fastdepCXX := 1
@BUILD_HDF5_TRUE@BUILD_HDF5 := 1
